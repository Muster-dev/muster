#!/usr/bin/env bash
# muster — Universal deploy framework
# Copyright 2026 Ricky Eipper. Licensed under Apache 2.0.
# https://getmuster.dev | https://github.com/Muster-dev/muster
set -uo pipefail

MUSTER_VERSION="0.5.50"

# Resolve symlinks (macOS bash 3.2 has no readlink -f)
_muster_self="${BASH_SOURCE[0]}"
while [[ -L "$_muster_self" ]]; do
  _muster_dir="$(cd "$(dirname "$_muster_self")" && pwd)"
  _muster_self="$(readlink "$_muster_self")"
  [[ "$_muster_self" != /* ]] && _muster_self="${_muster_dir}/${_muster_self}"
done
MUSTER_ROOT="$(cd "$(dirname "$_muster_self")/.." && pwd)"
unset _muster_self _muster_dir

# ── Global flags ──
MUSTER_QUIET="${MUSTER_QUIET:-false}"
MUSTER_VERBOSE="${MUSTER_VERBOSE:-false}"
MUSTER_MINIMAL="${MUSTER_MINIMAL:-false}"
MUSTER_NO_VERIFY="${MUSTER_NO_VERIFY:-false}"

_muster_args=()
for _arg in "$@"; do
  case "$_arg" in
    --quiet|-q) MUSTER_QUIET=true ;;
    --verbose)  MUSTER_VERBOSE=true ;;
    --minimal)  MUSTER_MINIMAL=true ;;
    --no-verify) MUSTER_NO_VERIFY=true ;;
    *)          _muster_args[${#_muster_args[@]}]="$_arg" ;;
  esac
done
set -- "${_muster_args[@]+"${_muster_args[@]}"}"
unset _muster_args _arg
export MUSTER_QUIET MUSTER_VERBOSE MUSTER_MINIMAL MUSTER_NO_VERIFY

# ── App integrity check (inline — no sourced deps for trust bootstrap) ──
if [[ -f "$MUSTER_ROOT/.muster.manifest" && "${MUSTER_NO_VERIFY}" != "true" ]]; then
  _integrity_fail=false

  # Step 1: Verify manifest signature (inline openssl — no sourced code)
  _m_sig_file="$MUSTER_ROOT/.muster.manifest.sig"
  _m_pubkey="$HOME/.muster/fleet/keys/payload.pub.pem"
  if [[ -f "$_m_sig_file" && -f "$_m_pubkey" ]]; then
    _m_tmp_sig="/tmp/.muster_boot_sig_$$"
    cat "$_m_sig_file" | base64 -d > "$_m_tmp_sig" 2>/dev/null
    if ! openssl pkeyutl -verify -pubin -inkey "$_m_pubkey" \
      -in "$MUSTER_ROOT/.muster.manifest" -sigfile "$_m_tmp_sig" >/dev/null 2>&1; then
      _integrity_fail=true
    fi
    rm -f "$_m_tmp_sig"
  fi

  # Step 2: Verify critical libs before sourcing (inline shasum — no sourced code)
  _m_tampered_files=""
  if [[ "$_integrity_fail" == "false" ]]; then
    _m_manifest=$(cat "$MUSTER_ROOT/.muster.manifest" 2>/dev/null)
    for _m_lib in lib/core/app_verify.sh lib/core/payload_sign.sh; do
      _m_file="$MUSTER_ROOT/$_m_lib"
      [[ ! -f "$_m_file" ]] && continue
      # Extract expected hash from single-line JSON manifest
      _m_expected=$(printf '%s' "$_m_manifest" \
        | grep -o "\"${_m_lib}\":{\"sha256\":\"[a-f0-9]*\"" \
        | sed 's/.*"sha256":"//;s/"//')
      [[ -z "$_m_expected" ]] && continue
      _m_actual=$(shasum -a 256 "$_m_file" 2>/dev/null | cut -d' ' -f1)
      if [[ "$_m_actual" != "$_m_expected" ]]; then
        _integrity_fail=true
        _m_tampered_files="$_m_lib"
        break
      fi
    done
  fi

  # Step 3: If bootstrap passed, source libs and run full verify
  if [[ "$_integrity_fail" == "false" ]]; then
    source "$MUSTER_ROOT/lib/core/payload_sign.sh"
    source "$MUSTER_ROOT/lib/core/app_verify.sh"
    if ! _app_verify_full >/dev/null 2>&1; then
      _integrity_fail=true
      # Collect tampered/missing file names
      _m_i=0
      while (( _m_i < ${#_APP_VERIFY_FILES[@]} )); do
        case "${_APP_VERIFY_RESULTS[$_m_i]}" in
          tampered|missing)
            [[ -n "$_m_tampered_files" ]] && _m_tampered_files="${_m_tampered_files}|"
            _m_tampered_files="${_m_tampered_files}${_APP_VERIFY_FILES[$_m_i]}"
            ;;
        esac
        _m_i=$(( _m_i + 1 ))
      done
    fi
  fi

  # Step 4: Handle failure — warn + show tampered files + offer repair
  if [[ "$_integrity_fail" == "true" ]]; then
    printf '\n\033[31m  ✗ App integrity check failed — files may have been tampered with\033[0m\n' >&2
    # Show tampered files
    if [[ -n "$_m_tampered_files" ]]; then
      IFS='|'
      for _m_tf in $_m_tampered_files; do
        printf '\033[31m    ✗ %s\033[0m\n' "$_m_tf" >&2
      done
      unset IFS
    fi
    printf '\033[2m  --no-verify to skip\033[0m\n\n' >&2
    if [[ -t 0 && -d "$MUSTER_ROOT/.git" ]]; then
      printf '  Repair from git and regenerate manifest? [Y/n] '
      IFS= read -rsn1 _repair || true
      printf '\n'
      case "$_repair" in
        n|N)
          printf '\033[33m  ⚠ Continuing with unverified files\033[0m\n\n' >&2
          ;;
        *)
          if (cd "$MUSTER_ROOT" && git checkout -- . 2>/dev/null); then
            # Source fresh (trusted) libs to regenerate manifest
            source "$MUSTER_ROOT/lib/core/app_verify.sh"
            _app_manifest_generate
            if [[ -f "$HOME/.muster/fleet/keys/payload.key.pem" ]]; then
              source "$MUSTER_ROOT/lib/core/payload_sign.sh"
              _app_manifest_sign 2>/dev/null
            fi
            printf '\033[32m  ✓ Files restored and manifest regenerated\033[0m\n\n'
            exec "$MUSTER_ROOT/bin/muster" "$@"
          else
            printf '\033[31m  ✗ Git repair failed\033[0m\n' >&2
            printf '\033[2m  Try: cd %s && git checkout -- .\033[0m\n\n' "$MUSTER_ROOT" >&2
          fi
          ;;
      esac
    fi
  fi
  unset _integrity_fail _m_sig_file _m_pubkey _m_tmp_sig _m_manifest _m_lib _m_file _m_expected _m_actual _repair
fi

# ── Fast path: no lib loading needed ──
case "${1:-}" in
  --version|-v)
    echo "v${MUSTER_VERSION}"
    exit 0
    ;;
esac

# ── Load core libraries ──
source "$MUSTER_ROOT/lib/core/colors.sh"
source "$MUSTER_ROOT/lib/core/logger.sh"
source "$MUSTER_ROOT/lib/core/utils.sh"
source "$MUSTER_ROOT/lib/core/config.sh"
source "$MUSTER_ROOT/lib/core/platform.sh"
source "$MUSTER_ROOT/lib/core/registry.sh"

# ── Apply persistent minimal setting ──
if [[ "$MUSTER_MINIMAL" != "true" ]]; then
  _min_val=$(global_config_get "minimal" 2>/dev/null || true)
  if [[ "$_min_val" == "true" ]]; then
    MUSTER_MINIMAL=true
    export MUSTER_MINIMAL
  fi
  unset _min_val
fi

# ── Route commands ──
case "${1:-}" in
  setup)
    shift
    source "$MUSTER_ROOT/lib/commands/setup.sh"
    cmd_setup "$@"
    ;;
  deploy)
    shift
    source "$MUSTER_ROOT/lib/commands/deploy.sh"
    cmd_deploy "$@"
    # Return to dashboard if interactive (skip in JSON mode)
    _has_json=false
    for _arg in "$@"; do [[ "$_arg" == "--json" ]] && _has_json=true; done
    if [[ "$_has_json" == "false" && -t 0 ]]; then
      echo ""
      printf '  %bPress any key to continue...%b' "${DIM}" "${RESET}"
      IFS= read -rsn1 || true
      source "$MUSTER_ROOT/lib/tui/dashboard.sh"
      cmd_dashboard
    fi
    ;;
  status)
    shift
    source "$MUSTER_ROOT/lib/commands/status.sh"
    cmd_status "$@"
    ;;
  logs)
    shift
    source "$MUSTER_ROOT/lib/commands/logs.sh"
    cmd_logs "$@"
    ;;
  rollback)
    shift
    source "$MUSTER_ROOT/lib/commands/rollback.sh"
    cmd_rollback "$@"
    ;;
  dev)
    shift
    source "$MUSTER_ROOT/lib/commands/dev.sh"
    cmd_dev "$@"
    ;;
  history)
    shift
    source "$MUSTER_ROOT/lib/commands/history.sh"
    cmd_history "$@"
    ;;
  diff)
    shift
    source "$MUSTER_ROOT/lib/commands/diff.sh"
    cmd_diff "$@"
    ;;
  doctor)
    shift
    source "$MUSTER_ROOT/lib/commands/doctor.sh"
    cmd_doctor "$@"
    ;;
  hooks)
    shift
    source "$MUSTER_ROOT/lib/commands/hooks.sh"
    cmd_hooks "$@"
    ;;
  cleanup)
    source "$MUSTER_ROOT/lib/commands/cleanup.sh"
    cmd_cleanup
    ;;
  settings)
    shift
    source "$MUSTER_ROOT/lib/commands/settings.sh"
    cmd_settings "$@"
    ;;
  uninstall)
    shift
    source "$MUSTER_ROOT/lib/commands/uninstall.sh"
    cmd_uninstall "$@"
    ;;
  skill)
    shift
    source "$MUSTER_ROOT/lib/skills/manager.sh"
    cmd_skill "$@"
    ;;
  addon)
    shift
    source "$MUSTER_ROOT/lib/commands/addon.sh"
    cmd_addon "$@"
    ;;
  projects)
    shift
    source "$MUSTER_ROOT/lib/commands/projects.sh"
    cmd_projects "$@"
    ;;
  auth)
    shift
    source "$MUSTER_ROOT/lib/core/auth.sh"
    source "$MUSTER_ROOT/lib/commands/auth.sh"
    cmd_auth "$@"
    ;;
  fleet)
    shift
    source "$MUSTER_ROOT/lib/commands/fleet.sh"
    cmd_fleet "$@"
    ;;
  group)
    shift
    source "$MUSTER_ROOT/lib/commands/group.sh"
    cmd_group "$@"
    ;;
  trust)
    shift
    source "$MUSTER_ROOT/lib/commands/trust.sh"
    cmd_trust "$@"
    ;;
  verify)
    shift
    source "$MUSTER_ROOT/lib/core/payload_sign.sh"
    source "$MUSTER_ROOT/lib/core/app_verify.sh"
    source "$MUSTER_ROOT/lib/commands/verify.sh"
    cmd_verify "$@"
    ;;
  update|--update)
    source "$MUSTER_ROOT/lib/core/updater.sh"
    update_apply
    ;;
  help|--help|-h)
    printf '%bmuster%b — Universal deploy framework\n' "${BOLD}" "${RESET}"
    echo ""
    echo "Usage: muster [command]"
    echo ""
    echo "Project commands:"
    echo "  (none)      Open the dashboard"
    echo "  setup       Guided setup wizard (or setup --help for flags)"
    echo "  deploy      Deploy services (--dry-run to preview, <service> for one)"
    echo "  dev         Deploy + watch health (Ctrl+C to cleanup)"
    echo "  status      Check service health"
    echo "  logs        Stream service logs"
    echo "  rollback    Revert last deploy"
    echo "  diff        Show what changed since last deploy (<service> or all)"
    echo "  history     Show deploy/rollback history (--all, <service>)"
    echo "  hooks       List and inspect hook scripts (hooks <svc> <hook>)"
    echo "  doctor      Run project diagnostics (--fix to auto-repair)"
    echo "  cleanup     Clean up stuck processes"
    echo "  settings    View and edit project/global settings"
    echo "  uninstall   Remove muster from project (--system to uninstall muster itself)"
    echo ""
    echo "Fleet commands:"
    echo "  fleet       Deploy one project to multiple machines (SSH or cloud)"
    echo "  group       Orchestrate multiple projects as one deploy (local, SSH, or cloud)"
    echo "  trust       Manage fleet deploy trust (accept, reject, revoke)"
    echo "  deploy fleet <group>   Shortcut for 'muster group deploy <group>'"
    echo ""
    echo "Other:"
    echo "  skill       Manage addon skills (add, create, remove, list, run)"
    echo "  projects    List registered projects (--prune to clean stale)"
    echo "  auth        Manage API tokens (create, list, revoke, verify)"
    echo "  verify      Verify app file integrity (--quick for signature only)"
    echo "  update      Update muster (release channel by default, see settings)"
    echo ""
    echo "Options:"
    echo "  -v, --version   Show version"
    echo "  -q, --quiet     Suppress info output (errors and warnings still shown)"
    echo "  --verbose       Show debug output"
    echo "  --minimal       Plain text output, numbered menus, no TUI"
    echo "  --no-verify     Skip app file integrity check"
    echo "  -h, --help      Show this help"
    echo ""
    echo "To always use minimal mode:"
    echo "  muster settings --global minimal true"
    ;;
  "")
    # Minimal mode: plain text status, no TUI
    if [[ "$MUSTER_MINIMAL" == "true" ]]; then
      if find_config &>/dev/null; then
        load_config
        source "$MUSTER_ROOT/lib/core/build_context.sh"

        _project=$(config_get '.project')
        echo "muster: ${_project}"

        # shellcheck disable=SC2178
        _services=$(config_services)
        _svc_count=0; _healthy=0; _unhealthy=0; _disabled=0
        # shellcheck disable=SC2128
        while IFS= read -r _svc; do
          [[ -z "$_svc" ]] && continue
          _svc_count=$(( _svc_count + 1 ))
          _hstatus=""
          if [[ -f "${HOME}/.muster/health_cache/${_svc}" ]]; then
            _hstatus=$(cat "${HOME}/.muster/health_cache/${_svc}")
          fi
          _name=$(config_get ".services.${_svc}.name")
          case "$_hstatus" in
            healthy)   _healthy=$(( _healthy + 1 )); echo "  ${_name}: healthy" ;;
            unhealthy) _unhealthy=$(( _unhealthy + 1 )); echo "  ${_name}: unhealthy" ;;
            disabled)  _disabled=$(( _disabled + 1 )); echo "  ${_name}: disabled" ;;
            *)         echo "  ${_name}: unknown" ;;
          esac
        done <<< "$_services"

        echo "muster: ${_svc_count} services (${_healthy} healthy, ${_unhealthy} unhealthy, ${_disabled} disabled)"

        # Build context warnings to stderr
        _build_context_warn_minimal
      else
        echo "muster: no project found (run muster setup)"
      fi
      exit 0
    fi

    # Check tui_mode setting (default: "go" when muster-tui installed)
    _tui_mode="go"
    _settings_file="$HOME/.muster/settings.json"
    if [[ -f "$_settings_file" ]] && has_cmd jq; then
      _tui_mode_val=$(jq -r '.tui_mode // "go"' "$_settings_file" 2>/dev/null)
      [[ -n "$_tui_mode_val" ]] && _tui_mode="$_tui_mode_val"
    fi

    # Launch Go TUI if tui_mode is "go" and muster-tui is installed
    if [[ "$_tui_mode" == "go" ]] && command -v muster-tui >/dev/null 2>&1; then
      _tui_config="$HOME/.muster/tui/config.json"
      _tui_has_token=false

      # Migrate old muster-tui config
      if [[ -f "$HOME/.muster-tui/config.json" && ! -f "$_tui_config" ]]; then
        mkdir -p "$HOME/.muster/tui"
        cp "$HOME/.muster-tui/config.json" "$_tui_config"
        chmod 600 "$_tui_config"
      fi

      # Check if muster-tui already has a token
      if [[ -f "$_tui_config" ]] && has_cmd jq; then
        _tui_tok=$(jq -r '.token // ""' "$_tui_config" 2>/dev/null)
        [[ -n "$_tui_tok" ]] && _tui_has_token=true
      fi

      # Auto-pair: create token and save to muster-tui config
      if [[ "$_tui_has_token" = false ]]; then
        source "$MUSTER_ROOT/lib/core/auth.sh"
        _tui_token=""
        if _tui_token=$(_auth_create_token_internal "muster-tui" "admin" 2>/dev/null) && [[ -n "$_tui_token" ]]; then
          muster-tui --set-token "$_tui_token" >/dev/null 2>&1 && _tui_has_token=true
        fi
      fi

      # Only launch if token is configured
      if [[ "$_tui_has_token" = true ]]; then
        exec muster-tui
      fi
    fi

    # Fallback to bash TUI
    source "$MUSTER_ROOT/lib/tui/dashboard.sh"
    cmd_dashboard
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'muster --help' for usage."
    exit 1
    ;;
esac
