#!/usr/bin/env bash
# muster — Universal deploy framework
# Copyright 2026 Ricky Eipper. Licensed under Apache 2.0.
# https://getmuster.dev | https://github.com/ImJustRicky/muster
set -uo pipefail

MUSTER_VERSION="0.5.8"

# Resolve symlinks (macOS bash 3.2 has no readlink -f)
_muster_self="${BASH_SOURCE[0]}"
while [[ -L "$_muster_self" ]]; do
  _muster_dir="$(cd "$(dirname "$_muster_self")" && pwd)"
  _muster_self="$(readlink "$_muster_self")"
  [[ "$_muster_self" != /* ]] && _muster_self="${_muster_dir}/${_muster_self}"
done
MUSTER_ROOT="$(cd "$(dirname "$_muster_self")/.." && pwd)"
unset _muster_self _muster_dir

# ── Fast path: no lib loading needed ──
case "${1:-}" in
  --version|-v)
    echo "v${MUSTER_VERSION}"
    exit 0
    ;;
esac

# ── Load core libraries ──
source "$MUSTER_ROOT/lib/core/colors.sh"
source "$MUSTER_ROOT/lib/core/logger.sh"
source "$MUSTER_ROOT/lib/core/utils.sh"
source "$MUSTER_ROOT/lib/core/config.sh"
source "$MUSTER_ROOT/lib/core/platform.sh"
source "$MUSTER_ROOT/lib/core/registry.sh"

# ── Route commands ──
case "${1:-}" in
  setup)
    shift
    source "$MUSTER_ROOT/lib/commands/setup.sh"
    cmd_setup "$@"
    ;;
  deploy)
    shift
    source "$MUSTER_ROOT/lib/commands/deploy.sh"
    cmd_deploy "$@"
    # Return to dashboard if interactive (skip in JSON mode)
    _has_json=false
    for _arg in "$@"; do [[ "$_arg" == "--json" ]] && _has_json=true; done
    if [[ "$_has_json" == "false" && -t 0 ]]; then
      echo ""
      echo -e "  ${DIM}Press any key to continue...${RESET}"
      IFS= read -rsn1 || true
      source "$MUSTER_ROOT/lib/tui/dashboard.sh"
      cmd_dashboard
    fi
    ;;
  status)
    shift
    source "$MUSTER_ROOT/lib/commands/status.sh"
    cmd_status "$@"
    ;;
  logs)
    shift
    source "$MUSTER_ROOT/lib/commands/logs.sh"
    cmd_logs "$@"
    ;;
  rollback)
    shift
    source "$MUSTER_ROOT/lib/commands/rollback.sh"
    cmd_rollback "$@"
    ;;
  dev)
    shift
    source "$MUSTER_ROOT/lib/commands/dev.sh"
    cmd_dev "$@"
    ;;
  history)
    shift
    source "$MUSTER_ROOT/lib/commands/history.sh"
    cmd_history "$@"
    ;;
  doctor)
    shift
    source "$MUSTER_ROOT/lib/commands/doctor.sh"
    cmd_doctor "$@"
    ;;
  cleanup)
    source "$MUSTER_ROOT/lib/commands/cleanup.sh"
    cmd_cleanup
    ;;
  settings)
    shift
    source "$MUSTER_ROOT/lib/commands/settings.sh"
    cmd_settings "$@"
    ;;
  uninstall)
    shift
    source "$MUSTER_ROOT/lib/commands/uninstall.sh"
    cmd_uninstall "$@"
    ;;
  skill)
    shift
    source "$MUSTER_ROOT/lib/skills/manager.sh"
    cmd_skill "$@"
    ;;
  projects)
    shift
    source "$MUSTER_ROOT/lib/commands/projects.sh"
    cmd_projects "$@"
    ;;
  auth)
    shift
    source "$MUSTER_ROOT/lib/core/auth.sh"
    source "$MUSTER_ROOT/lib/commands/auth.sh"
    cmd_auth "$@"
    ;;
  fleet)
    shift
    source "$MUSTER_ROOT/lib/commands/fleet.sh"
    cmd_fleet "$@"
    ;;
  update|--update)
    source "$MUSTER_ROOT/lib/core/updater.sh"
    update_apply
    ;;
  --help|-h)
    echo -e "${BOLD}muster${RESET} — Universal deploy framework"
    echo ""
    echo "Usage: muster [command]"
    echo ""
    echo "Commands:"
    echo "  (none)      Open the dashboard"
    echo "  setup       Guided setup wizard (or setup --help for flags)"
    echo "  deploy      Deploy services (--dry-run to preview, <service> for one)"
    echo "  dev         Deploy + watch health (Ctrl+C to cleanup)"
    echo "  status      Check service health"
    echo "  logs        Stream service logs"
    echo "  rollback    Revert last deploy"
    echo "  history     Show deploy/rollback history (--all, <service>)"
    echo "  doctor      Run project diagnostics (--fix to auto-repair)"
    echo "  cleanup     Clean up stuck processes"
    echo "  settings    View and edit project/global settings"
    echo "  uninstall   Remove muster from project (--system to uninstall muster itself)"
    echo "  skill       Manage addon skills (add, create, remove, list, run)"
    echo "  projects    List registered projects (--prune to clean stale)"
    echo "  auth        Manage API tokens (create, list, revoke, verify)"
    echo "  fleet       Manage fleet deployments across machines"
    echo "  update      Update muster to latest version"
    echo ""
    echo "Options:"
    echo "  -v, --version   Show version"
    echo "  -h, --help      Show this help"
    ;;
  "")
    # Check tui_mode setting (default: "go" when muster-tui installed)
    _tui_mode="go"
    _settings_file="$HOME/.muster/settings.json"
    if [[ -f "$_settings_file" ]] && has_cmd jq; then
      _tui_mode_val=$(jq -r '.tui_mode // "go"' "$_settings_file" 2>/dev/null)
      [[ -n "$_tui_mode_val" ]] && _tui_mode="$_tui_mode_val"
    fi

    # Launch Go TUI if tui_mode is "go" and muster-tui is installed
    if [[ "$_tui_mode" == "go" ]] && command -v muster-tui >/dev/null 2>&1; then
      _tui_config="$HOME/.muster-tui/config.json"
      _tui_has_token=false

      # Check if muster-tui already has a token
      if [[ -f "$_tui_config" ]] && has_cmd jq; then
        _tui_tok=$(jq -r '.token // ""' "$_tui_config" 2>/dev/null)
        [[ -n "$_tui_tok" ]] && _tui_has_token=true
      fi

      # Auto-pair: create token and save to muster-tui config
      if [[ "$_tui_has_token" = false ]]; then
        source "$MUSTER_ROOT/lib/core/auth.sh"
        _tui_token=""
        if _tui_token=$(_auth_create_token_internal "muster-tui" "admin" 2>/dev/null) && [[ -n "$_tui_token" ]]; then
          muster-tui --set-token "$_tui_token" >/dev/null 2>&1 && _tui_has_token=true
        fi
      fi

      # Only launch if token is configured
      if [[ "$_tui_has_token" = true ]]; then
        exec muster-tui
      fi
    fi

    # Fallback to bash TUI
    source "$MUSTER_ROOT/lib/tui/dashboard.sh"
    cmd_dashboard
    ;;
  *)
    err "Unknown command: $1"
    echo "Run 'muster --help' for usage."
    exit 1
    ;;
esac
